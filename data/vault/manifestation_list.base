views:
  - type: table
    name: Table
    filters:
      and:
        - class == "Manifestation"
    order:
      - file.name
      - image
      - local_asset_path
      - contributor
      - has_version
      - instance_of
      - instrumentation
      - part_of
      - title
      - based_on
    sort:
      - property: image
        direction: ASC
      - property: local_asset_path
        direction: ASC
    columnSize:
      note.image: 327
